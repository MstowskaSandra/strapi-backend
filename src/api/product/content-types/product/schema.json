{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Brand": {
      "type": "string"
    },
    "Title": {
      "type": "string"
    },
    "Description": {
      "type": "text"
    },
    "Volume": {
      "type": "string"
    },
    "Strength": {
      "type": "string"
    },
    "Flavor": {
      "type": "string"
    },
    "Price": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "Brand"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "mappedBy": "products"
    }
  }
}
