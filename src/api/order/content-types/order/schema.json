      "type": "string"
    },
    "customerName": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "phone": {
      "type": "string"
    },
    "shop": {
      "type": "enumeration",
      "enum": [
        "Olawa",
        "Strzelin"
      ]
    },
    "items": {
      "type": "json"
    },
    "totalPrice": {
      "type": "string"
    },
    "OrderStatus": {
      "type": "enumeration",
      "enum": [
